# MetaAPI Cloud splits its REST API across two hosts:
#   - Provisioning API (create/list/delete MT5 accounts)
#   - Client API (per-account operations: candles, prices, trades, positions)
# Both are configured below. TLS verification is disabled per-request inside
# src/lib/metaapi.ts because some MetaAPI regions ship an incomplete
# certificate chain ("unable to verify the first certificate" error).
META_API_PROVISIONING_DOMAIN=mt-provisioning.cloud-trail.com
# Pick the region closest to your broker's server for lower latency.
# Valid values: new-york | london | hong-kong
META_API_CLIENT_REGION=new-york
# Optional: override the full client domain (otherwise derived from region).
# META_API_CLIENT_DOMAIN=mt-client-api-v1.new-york.agiliumtrade.ai
# Legacy single-domain override — leave UNSET to use the split architecture above.
# META_API_DOMAIN=

# --- Telegram bot (operator-only) ---
TELEGRAM_BOT_TOKEN=8923618974:AAGW5G3-PTCWGUxv42VTn_oOEE8vXHnbzGg
ADMIN_TELEGRAM_ID=8258176711
# The base URL of this Next.js app, used by the Telegram bot to call /api/codes/generate
ALFA_APP_BASE_URL=http://localhost:3000

# --- Shared admin secret ---
# The Telegram bot must send this in the X-Admin-Token header to generate codes.
ADMIN_API_TOKEN=alfa-reports-admin-secret-2026

# --- MT5 user credentials ---
# IMPORTANT: Each subscriber enters their OWN MT5 credentials (ID/Password/Server)
# in the login screen. The system provisions a separate MetaAPI account per MT5
# login, so multiple subscribers can trade simultaneously, each on their own
# account. NO MT5 credentials are stored in env vars.
# Passwords are hashed (scrypt + salt) at runtime and only sent to MetaAPI at
# provisioning time, then discarded from memory.
