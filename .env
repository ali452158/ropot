# === ALFA Reports — Environment Variables ===

# --- Database ---
DATABASE_URL=file:/home/z/my-project/db/custom.db

# --- MetaAPI Cloud (production) ---
# Set this on the VPS to enable LIVE trading. Leave empty to run in SIMULATION mode.
META_API_TOKEN=
META_API_DOMAIN=agiliumtrade.agiliumtrade.ai

# --- Telegram bot (operator-only) ---
# Get these from @BotFather and @userinfobot
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=
# The base URL of this Next.js app, used by the Telegram bot to call /api/codes/generate
ALFA_APP_BASE_URL=http://localhost:3000

# --- Shared admin secret ---
# The Telegram bot must send this in the X-Admin-Token header to generate codes.
ADMIN_API_TOKEN=change-this-to-a-long-random-string

# Note: MT5 user passwords are NEVER stored in env vars. They are entered at runtime
# in the MT5 login screen, hashed (scrypt + salt), and only sent to MetaAPI at
# provisioning time, then discarded from memory.
