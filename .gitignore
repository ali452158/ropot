# === ALFA Reports .gitignore ===
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# === Dependencies ===
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
bun.lockb

# === Next.js ===
/.next/
/out/
/build
/dist/

# === Production ===
*.tsbuildinfo
next-env.d.ts

# === Environment ===
.env
.env.local
.env.*.local
.env.production
.env.development

# === Database (local SQLite) ===
db/*.db
db/*.db-journal
db/*.sqlite
db/*.sqlite-journal

# === Logs ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
dev.out.log
server.log

# === Misc ===
.DS_Store
*.pem
*.swp
.idea/
.vscode/
.tox
.claude
.z-ai-config
local-*
.vercel
prompt

# === ALFA-specific ===
/skills/
/examples/
/mini-services/node_modules/
/mini-services/*/node_modules/
/mini-services/*/bun.lock
/mini-services/*/.next/
/upload/
/tool-results/
/agent-ctx/
/worklog.md

# === Keep these (do NOT ignore) ===
!.env.example
!.gitignore
!README.md
